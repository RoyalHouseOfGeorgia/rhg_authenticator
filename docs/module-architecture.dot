digraph module_architecture {
    rankdir=TB;
    bgcolor="transparent";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2];
    edge [color="#868e96", penwidth=0.8];
    compound=true;

    // TypeScript verification library
    subgraph cluster_ts {
        label="TypeScript — Verification Library";
        labeljust=l;
        style="dashed,rounded";
        color="#4263eb";
        fontname="Helvetica";
        fontsize=10;
        fontcolor="#4263eb";

        index [label="index.ts\n(barrel export)", fillcolor="#dbe4ff", color="#4263eb"];
        verify [label="verify.ts\n(orchestrator)", fillcolor="#dbe4ff", color="#4263eb"];
        verify_page [label="verify-page.ts\n(browser UI)", fillcolor="#dbe4ff", color="#4263eb"];
        credential [label="credential.ts\n(schema + sanitize)", fillcolor="#dbe4ff", color="#4263eb"];
        crypto [label="crypto.ts\n(Ed25519)", fillcolor="#dbe4ff", color="#4263eb"];
        registry [label="registry.ts\n(key registry)", fillcolor="#dbe4ff", color="#4263eb"];
        validation [label="validation.ts\n(date utils)", fillcolor="#dbe4ff", color="#4263eb"];
        base64url [label="base64url.ts\n(encoding)", fillcolor="#dbe4ff", color="#4263eb"];
        canonical [label="canonical.ts\n(JSON serializer)", fillcolor="#dbe4ff", color="#4263eb"];
    }

    // Go signing app
    subgraph cluster_go {
        label="Go — Desktop Signing App";
        labeljust=l;
        style="dashed,rounded";
        color="#e67700";
        fontname="Helvetica";
        fontsize=10;
        fontcolor="#e67700";

        go_gui [label="gui/\n(Fyne GUI — 5 tabs)", fillcolor="#fff3bf", color="#e67700"];
        go_core [label="core/\n(credential, canonical,\nregistry, sign)", fillcolor="#fff3bf", color="#e67700"];
        go_regmgr [label="regmgr/\n(Registry Manager tab)", fillcolor="#fff3bf", color="#e67700"];
        go_ghapi [label="ghapi/\n(GitHub OAuth +\nREST API)", fillcolor="#fff3bf", color="#e67700"];
        go_yubikey [label="yubikey/\n(piv-go PIV adapter\n+ PIN cache)", fillcolor="#fff3bf", color="#e67700"];
        go_qr [label="qr/\n(SVG + PNG)", fillcolor="#fff3bf", color="#e67700"];
        go_log [label="log/\n(issuance log)", fillcolor="#fff3bf", color="#e67700"];
        go_registry [label="registry/\n(remote fetch)", fillcolor="#fff3bf", color="#e67700"];
    }

    // External deps
    noble [label="@noble/curves\n(Ed25519)", shape=component, fillcolor="#d3f9d8", color="#2b8a3e"];
    pivgo [label="piv-go\n(PCSC)", shape=component, fillcolor="#d3f9d8", color="#2b8a3e"];
    fyne [label="fyne\n(GUI)", shape=component, fillcolor="#d3f9d8", color="#2b8a3e"];
    keyring [label="go-keyring\n(OS keychain)", shape=component, fillcolor="#d3f9d8", color="#2b8a3e"];

    // Cross-language link
    vectors [label="Cross-language\ntest vectors", shape=note, fillcolor="#e9ecef", color="#868e96"];

    // TypeScript core deps
    verify -> credential;
    verify -> crypto;
    verify -> registry;
    verify_page -> verify;
    verify_page -> base64url;
    verify_page -> registry;
    credential -> validation;
    registry -> base64url;
    registry -> validation;
    crypto -> noble;

    // Go internal deps
    go_gui -> go_core;
    go_gui -> go_yubikey;
    go_gui -> go_qr;
    go_gui -> go_log;
    go_gui -> go_registry;
    go_regmgr -> go_core;
    go_regmgr -> go_ghapi;
    go_regmgr -> go_yubikey;
    go_yubikey -> pivgo;
    go_gui -> fyne;
    go_regmgr -> fyne;
    go_ghapi -> keyring;

    // Cross-language
    go_core -> vectors [style=dotted, dir=both, label="byte-identical\noutput"];
    canonical -> vectors [style=dotted, dir=both];
}
