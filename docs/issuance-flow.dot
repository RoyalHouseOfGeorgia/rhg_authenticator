digraph issuance_flow {
    rankdir=LR;
    bgcolor="transparent";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, fillcolor="#f8f9fa", color="#495057", penwidth=1.2];
    edge [fontname="Helvetica", fontsize=9, color="#6c757d"];

    // Principals
    subgraph cluster_app {
        label="Desktop App (Go + Fyne GUI)";
        labeljust=l;
        style="dashed,rounded";
        color="#868e96";
        fontname="Helvetica";
        fontsize=10;
        fontcolor="#495057";

        form [label="Credential Form\n(recipient, honor,\ndetail, date)", fillcolor="#dbe4ff"];
        validate [label="Validate\ncredential"];
        canonicalize [label="Canonicalize\n(JSON → bytes)"];
        sign_req [label="Sign via\npiv-go (PCSC)"];
        verify_rt [label="Verify\nround-trip"];
        log [label="Append to\nissuance log"];
        encode [label="Base64URL\nencode"];
        build_url [label="Build\nverification URL"];
        gen_qr [label="Generate QR\n(SVG + PNG)"];
    }

    yubikey [label="YubiKey\nPIV slot 9c\nEd25519", shape=cylinder, fillcolor="#fff3bf"];
    qr [label="QR Code\non Diploma", fillcolor="#ffe3e3", shape=note];

    // Flow
    form -> validate [label="credential fields"];
    validate -> canonicalize;
    canonicalize -> sign_req [label="canonical bytes"];
    sign_req -> yubikey [label="PIN via\nGUI dialog", style=dashed];
    yubikey -> sign_req [label="64-byte signature", style=dashed];
    sign_req -> verify_rt [label="signature"];
    verify_rt -> log;
    log -> encode;
    encode -> build_url [label="p=...&s=..."];
    build_url -> gen_qr [label="verification URL"];
    gen_qr -> qr [label="SVG for print\nPNG for preview"];
}
