{
  "name": "@rhg/authenticator",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:verify": "esbuild src/verify-page.ts --bundle --outfile=verify/verify.js --format=iife --target=es2020 --minify",
    "build:issuer": "esbuild src/issuer-page.ts --bundle --outfile=issuer/issuer.js --format=iife --platform=browser --target=es2020 --minify",
    "build:all": "npm run build && npm run build:verify && npm run build:issuer",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check:registry": "node -e \"const r=JSON.parse(require('fs').readFileSync('./keys/registry.json','utf8')); const TEST_KEY='/PjT+j342wWZypb0m/4MSBsFhHrrqzpoTe2rZ9hf0XU='; if(r.keys.some(k=>k.public_key===TEST_KEY)){console.error('ERROR: registry.json contains test key — replace before deployment');process.exit(1)}else{console.log('OK: no test keys found')}\"",
    "audit:deps": "npm audit --omit=dev",
    "start:server": "npx tsx src/server/cli.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "canvas": "^3.2.1",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.8.3",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
